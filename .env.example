# Backend port (Railway sets this automatically)
PORT=3001

# Cache directory for GDELT results
CACHE_DIR=./server/.cache

# Space-Track credentials (https://www.space-track.org)
SPACETRACK_LOGIN=your@email.com
SPACETRACK_PASSWORD=yourpassword

# OpenAI API key for GDELT enrichment
OPENAI_API_KEY=sk-...

# Google Cloud service account JSON (single line, no newlines)
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Frontend — set to your Railway backend URL
VITE_API_BASE=https://your-app.up.railway.app
